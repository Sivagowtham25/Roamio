<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>

    <application
        android:allowBackup="true"
        android:name=".RoamioApp"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Roamio">

        <!-- Google Maps API Key -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${mapsApiKey}"/>

        <!-- Home -->
        <activity
            android:name=".MainActivity"
            android:theme="@style/Theme.Roamio.Home"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login -->
        <activity
            android:name=".activities.LoginActivity"
            android:theme="@style/Theme.Roamio.Signup"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <!-- Signup -->
        <activity
            android:name=".activities.SignupActivity"
            android:theme="@style/Theme.Roamio.Signup"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <!-- Nearby -->
        <activity
            android:name=".activities.NearbyActivity"
            android:theme="@style/Theme.Roamio.Home"
            android:exported="false" />

        <!-- ✅ Trips landing page -->
        <activity
            android:name=".activities.TripsActivity"
            android:theme="@style/Theme.Roamio.Home"
            android:exported="false" />

        <!-- ✅ Create Trip manually -->
        <activity
            android:name=".activities.CreateTripActivity"
            android:theme="@style/Theme.Roamio.Signup"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <!-- ✅ AI Trip Planner (Gemini) -->
        <activity
            android:name=".activities.AiTripPlannerActivity"
            android:theme="@style/Theme.Roamio.Home"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <!-- ✅ Profile / Account page -->
        <activity
            android:name=".activities.ProfileActivity"
            android:theme="@style/Theme.Roamio.Signup"
            android:exported="false" />

    </application>

</manifest>
