<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/colorDeepNavy"
    android:fitsSystemWindows="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="60dp"
        android:paddingBottom="40dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="center_horizontal">

        <!-- ── Loading indicator ────────────────────────────────────────── -->
        <ProgressBar
            android:id="@+id/loadingView"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:layout_marginTop="120dp"
            android:indeterminateTint="@color/colorTeal"
            android:visibility="gone"/>

        <!-- ── Avatar + Name Card ───────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="20dp"
            app:cardBackgroundColor="@color/colorGlassCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal">

                <!-- Avatar circle with initial -->
                <TextView
                    android:id="@+id/tvUserInitial"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:gravity="center"
                    android:text="?"
                    android:textColor="@color/colorDeepNavy"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:background="@color/colorTeal"
                    android:layout_marginBottom="16dp"/>

                <!-- Name -->
                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <!-- Email -->
                <TextView
                    android:id="@+id/tvUserEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/colorTextMuted"
                    android:textSize="14sp"
                    android:layout_marginBottom="20dp"/>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/colorDivider"
                    android:layout_marginBottom="20dp"/>

                <!-- Age + Job row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Age -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            style="@style/FieldLabel"
                            android:text="AGE"
                            android:gravity="center"/>
                        <TextView
                            android:id="@+id/tvAge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Vertical divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="@color/colorDivider"/>

                    <!-- Job Type -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            style="@style/FieldLabel"
                            android:text="PROFESSION"
                            android:gravity="center"/>
                        <TextView
                            android:id="@+id/tvJobType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="—"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Trip Preferences Card ─────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardTrips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="20dp"
            app:cardBackgroundColor="@color/colorGlassCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    style="@style/FieldLabel"
                    android:text="TRIP PREFERENCES"
                    android:layout_marginBottom="14dp"/>

                <!-- Chips added dynamically -->
                <LinearLayout
                    android:id="@+id/llTripPreferences"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── AI Recommendations Card ──────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardAI"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="20dp"
            app:cardBackgroundColor="@color/colorGlassCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <!-- Header row with gold star -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✦"
                        android:textColor="@color/colorGold"
                        android:textSize="16sp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        style="@style/FieldLabel"
                        android:text="AI RECOMMENDATIONS"
                        android:layout_marginBottom="0dp"/>
                </LinearLayout>

                <!-- Rows added dynamically -->
                <LinearLayout
                    android:id="@+id/llAiRecommendations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Logout Button ─────────────────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Sign Out"
            android:textSize="15sp"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:backgroundTint="#22FFFFFF"
            app:strokeColor="@color/colorDivider"
            app:strokeWidth="1dp"
            app:cornerRadius="14dp"/>

    </LinearLayout>
</ScrollView>