<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_signup.xml
    Place at: app/src/main/res/layout/activity_signup.xml
    Requires: bg_glass_card, bg_glass_input, bg_trip_chip drawables (included in this set)
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/colorDeepNavy"
    android:fitsSystemWindows="false">

    <!-- Gradient background overlay -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="56dp"
        android:paddingBottom="40dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:gravity="center_horizontal">

        <!-- ── Logo Row ──────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="28dp">

            <TextView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="🧭"
                android:textSize="26sp"
                android:gravity="center"
                android:background="@drawable/bg_logo_circle"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI-POWERED TOURISM"
                    android:textColor="@color/colorTextMuted"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ── Heading ───────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Begin Your\nAdventure"
            android:textColor="@color/colorTextPrimary"
            android:textSize="30sp"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.1"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create an account to unlock personalised travel experiences."
            android:textColor="@color/colorTextMuted"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"/>

        <!-- ── Glass Card ─────────────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardForm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="20dp"
            app:cardBackgroundColor="@color/colorGlassCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <!-- ── Name + Age Row ───────────────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="14dp">

                    <!-- Name -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView style="@style/FieldLabel" android:text="FULL NAME"/>
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilName"
                            style="@style/GlassInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etName"
                                style="@style/GlassEditText"
                                android:hint="Your name"
                                android:inputType="textPersonName"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Age -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView style="@style/FieldLabel" android:text="AGE"/>
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilAge"
                            style="@style/GlassInputLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etAge"
                                style="@style/GlassEditText"
                                android:hint="25"
                                android:inputType="number"/>
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── Email ────────────────────────────────────────────── -->
                <TextView style="@style/FieldLabel" android:text="EMAIL ADDRESS"/>
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    style="@style/GlassInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEmail"
                        style="@style/GlassEditText"
                        android:hint="you@email.com"
                        android:inputType="textEmailAddress"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- ── Job Type Spinner ──────────────────────────────────── -->
                <TextView style="@style/FieldLabel" android:text="JOB TYPE"/>
                <Spinner
                    android:id="@+id/spinnerJobType"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_glass_input"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="18dp"/>

                <!-- ── Trip Types ────────────────────────────────────────── -->
                <TextView style="@style/FieldLabel" android:text="TYPES OF TRIPS YOU LOVE"
                    android:layout_marginBottom="10dp"/>

                <!-- Row 1 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="8dp">
                    <CheckBox android:id="@+id/cbAdventure" style="@style/TripChip"
                        android:layout_weight="1" android:text="🧗 Adventure" android:layout_marginEnd="5dp"/>
                    <CheckBox android:id="@+id/cbCultural" style="@style/TripChip"
                        android:layout_weight="1" android:text="🏛️ Cultural" android:layout_marginStart="5dp"/>
                </LinearLayout>
                <!-- Row 2 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="8dp">
                    <CheckBox android:id="@+id/cbBeach" style="@style/TripChip"
                        android:layout_weight="1" android:text="🏖️ Beach" android:layout_marginEnd="5dp"/>
                    <CheckBox android:id="@+id/cbNature" style="@style/TripChip"
                        android:layout_weight="1" android:text="🌿 Nature" android:layout_marginStart="5dp"/>
                </LinearLayout>
                <!-- Row 3 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="8dp">
                    <CheckBox android:id="@+id/cbCity" style="@style/TripChip"
                        android:layout_weight="1" android:text="🏙️ City" android:layout_marginEnd="5dp"/>
                    <CheckBox android:id="@+id/cbSpiritual" style="@style/TripChip"
                        android:layout_weight="1" android:text="🕌 Spiritual" android:layout_marginStart="5dp"/>
                </LinearLayout>
                <!-- Row 4 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="18dp">
                    <CheckBox android:id="@+id/cbLuxury" style="@style/TripChip"
                        android:layout_weight="1" android:text="💎 Luxury" android:layout_marginEnd="5dp"/>
                    <CheckBox android:id="@+id/cbBudget" style="@style/TripChip"
                        android:layout_weight="1" android:text="🎒 Budget" android:layout_marginStart="5dp"/>
                </LinearLayout>

                <!-- ── Password ──────────────────────────────────────────── -->
                <TextView style="@style/FieldLabel" android:text="PASSWORD"/>
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPassword"
                    style="@style/GlassInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/colorTextMuted">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPassword"
                        style="@style/GlassEditText"
                        android:hint="Create a strong password"
                        android:inputType="textPassword"/>
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Password Strength Bar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="22dp"
                    android:weightSum="4">
                    <View android:id="@+id/strengthSeg1" android:layout_width="0dp"
                        android:layout_height="match_parent" android:layout_weight="1"
                        android:background="@color/colorStrengthBlank" android:layout_marginEnd="3dp"/>
                    <View android:id="@+id/strengthSeg2" android:layout_width="0dp"
                        android:layout_height="match_parent" android:layout_weight="1"
                        android:background="@color/colorStrengthBlank" android:layout_marginEnd="3dp"/>
                    <View android:id="@+id/strengthSeg3" android:layout_width="0dp"
                        android:layout_height="match_parent" android:layout_weight="1"
                        android:background="@color/colorStrengthBlank" android:layout_marginEnd="3dp"/>
                    <View android:id="@+id/strengthSeg4" android:layout_width="0dp"
                        android:layout_height="match_parent" android:layout_weight="1"
                        android:background="@color/colorStrengthBlank"/>
                </LinearLayout>

                <!-- ── Sign Up Button ─────────────────────────────────────── -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSignup"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Create My Travel Profile"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    app:backgroundTint="@color/colorTeal"
                    app:cornerRadius="14dp"
                    app:elevation="10dp"/>

                <!-- ── Divider ────────────────────────────────────────────── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="14dp">
                    <View android:layout_width="0dp" android:layout_height="1dp"
                        android:layout_weight="1" android:background="@color/colorDivider"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="  Already a traveller?  "
                        android:textColor="@color/colorTextMuted" android:textSize="12sp"/>
                    <View android:layout_width="0dp" android:layout_height="1dp"
                        android:layout_weight="1" android:background="@color/colorDivider"/>
                </LinearLayout>

                <!-- ── Login Redirect ─────────────────────────────────────── -->
                <TextView
                    android:id="@+id/tvLoginRedirect"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Sign in to your account →"
                    android:textColor="@color/colorGold"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:paddingBottom="4dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
