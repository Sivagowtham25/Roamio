<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorDeepNavy">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="60dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CREATE PROFILE"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Join the Roamio community"
                android:textColor="@color/colorTextMuted"
                android:textSize="15sp"
                android:layout_marginBottom="32dp"/>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/colorGlassCard"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- NAME -->
                    <TextView style="@style/FieldLabel" android:text="Full Name" />
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/GlassInputLayout">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etName"
                            style="@style/GlassEditText"
                            android:hint="John Doe"
                            android:inputType="textPersonName"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- EMAIL -->
                    <TextView style="@style/FieldLabel" android:text="Email Address" android:layout_marginTop="16dp"/>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/GlassInputLayout">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            style="@style/GlassEditText"
                            android:hint="john@example.com"
                            android:inputType="textEmailAddress"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:baselineAligned="false"
                        android:layout_marginTop="16dp">

                        <!-- AGE -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">
                            <TextView style="@style/FieldLabel" android:text="Age" />
                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                style="@style/GlassInputLayout">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/etAge"
                                    style="@style/GlassEditText"
                                    android:hint="25"
                                    android:inputType="number"/>
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <!-- JOB -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView style="@style/FieldLabel" android:text="Profession" />
                            <Spinner
                                android:id="@+id/spinnerJobType"
                                android:layout_width="match_parent"
                                android:layout_height="54dp"
                                android:background="@drawable/bg_trip_chip"
                                android:paddingStart="8dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- PREFERENCES -->
                    <!-- ── Trip Types Label ──────────────────────────────────── -->
                    <TextView
                        style="@style/FieldLabel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="TYPES OF TRIPS YOU LOVE"
                        android:layout_marginBottom="10dp"/>

                    <!-- Row 1: Adventure + Cultural -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="8dp">

                        <CheckBox
                            android:id="@+id/cbAdventure"
                            style="@style/TripChip"
                            android:layout_weight="1"
                            android:text="🧗 Adventure"
                            android:layout_marginEnd="5dp"/>

                        <CheckBox
                            android:id="@+id/cbCultural"
                            style="@style/TripChip"
                            android:layout_weight="1"
                            android:text="🏛️ Cultural"
                            android:layout_marginStart="5dp"/>
                    </LinearLayout>

                    <!-- Row 2: Beach + Nature -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="8dp">

                        <CheckBox
                            android:id="@+id/cbBeach"
                            style="@style/TripChip"
                            android:layout_weight="1"
                            android:text="🏖️ Beach"
                            android:layout_marginEnd="5dp"/>

                        <CheckBox
                            android:id="@+id/cbNature"
                            style="@style/TripChip"
                            android:layout_weight="1"
                            android:text="🌿 Nature"
                            android:layout_marginStart="5dp"/>
                    </LinearLayout>

                    <!-- Row 3: City + Spiritual -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="8dp">

                        <CheckBox
                            android:id="@+id/cbCity"
                            style="@style/TripChip"
                            android:layout_weight="1"
                            android:text="🏙️ City"
                            android:layout_marginEnd="5dp"/>

                        <CheckBox
                            android:id="@+id/cbSpiritual"
                            style="@style/TripChip"
                            android:layout_weight="1"
                            android:text="🕌 Spiritual"
                            android:layout_marginStart="5dp"/>
                    </LinearLayout>

                    <!-- Row 4: Luxury + Budget -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="18dp">

                        <CheckBox
                            android:id="@+id/cbLuxury"
                            style="@style/TripChip"
                            android:layout_weight="1"
                            android:text="💎 Luxury"
                            android:layout_marginEnd="5dp"/>

                        <CheckBox
                            android:id="@+id/cbBudget"
                            style="@style/TripChip"
                            android:layout_weight="1"
                            android:text="🎒 Budget"
                            android:layout_marginStart="5dp"/>
                    </LinearLayout>

                    <!-- PASSWORD -->
                    <TextView style="@style/FieldLabel" android:text="Secure Password" android:layout_marginTop="20dp"/>
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/GlassInputLayout"
                        app:passwordToggleEnabled="true"
                        app:passwordToggleTint="@color/colorTextMuted">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPassword"
                            style="@style/GlassEditText"
                            android:hint="••••••••"
                            android:inputType="textPassword"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- STRENGTH BAR -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:weightSum="4">
                        <View android:id="@+id/strengthSeg1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@color/colorStrengthBlank" android:layout_marginEnd="4dp"/>
                        <View android:id="@+id/strengthSeg2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@color/colorStrengthBlank" android:layout_marginEnd="4dp"/>
                        <View android:id="@+id/strengthSeg3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@color/colorStrengthBlank" android:layout_marginEnd="4dp"/>
                        <View android:id="@+id/strengthSeg4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@color/colorStrengthBlank"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSignup"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="Create My Travel Profile"
                        android:textColor="@color/colorDeepNavy"
                        android:backgroundTint="@color/colorTeal"
                        android:layout_marginTop="32dp"
                        app:cornerRadius="16dp"
                        android:textStyle="bold"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvLoginRedirect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? Log In"
                android:textColor="@color/colorTeal"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                android:padding="12dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="40dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
