<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:paddingBottom="24dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="52dp">

            <!-- Back + Title row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp">

                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="←"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create a Trip"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_centerInParent="true"/>

            </RelativeLayout>

            <!-- Destination -->
            <TextView style="@style/FieldLabel" android:text="Destination"/>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/GlassInputLayout">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDestination"
                    style="@style/GlassEditText"
                    android:hint="e.g. Goa, Kerala, Paris..."
                    android:inputType="textCapWords"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Trip Name -->
            <TextView style="@style/FieldLabel"
                android:text="Trip Name"
                android:layout_marginTop="18dp"/>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/GlassInputLayout">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTripName"
                    style="@style/GlassEditText"
                    android:hint="e.g. Summer 2025 Road Trip"
                    android:inputType="textCapWords"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Dates row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="18dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">
                    <TextView style="@style/FieldLabel" android:text="Start Date"/>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/GlassInputLayout">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etStartDate"
                            style="@style/GlassEditText"
                            android:hint="DD/MM/YYYY"
                            android:focusable="false"
                            android:clickable="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">
                    <TextView style="@style/FieldLabel" android:text="End Date"/>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/GlassInputLayout">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEndDate"
                            style="@style/GlassEditText"
                            android:hint="DD/MM/YYYY"
                            android:focusable="false"
                            android:clickable="true"/>
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- Number of travellers -->
            <TextView style="@style/FieldLabel"
                android:text="Number of Travellers"
                android:layout_marginTop="18dp"/>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/GlassInputLayout">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTravellers"
                    style="@style/GlassEditText"
                    android:hint="e.g. 2"
                    android:inputType="number"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Budget -->
            <TextView style="@style/FieldLabel"
                android:text="Budget (₹)"
                android:layout_marginTop="18dp"/>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/GlassInputLayout">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etBudget"
                    style="@style/GlassEditText"
                    android:hint="e.g. 25000"
                    android:inputType="numberDecimal"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Notes -->
            <TextView style="@style/FieldLabel"
                android:text="Notes / Activities"
                android:layout_marginTop="18dp"/>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/GlassInputLayout">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNotes"
                    style="@style/GlassEditText"
                    android:hint="Add places, activities, or things to do..."
                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:gravity="top"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Save Trip Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveTrip"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Save Trip"
                android:textColor="#111111"
                android:backgroundTint="#FFFFFF"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_marginTop="32dp"
                app:cornerRadius="50dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
