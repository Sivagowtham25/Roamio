<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:weightSum="100">

    <!-- ── MAP (top 58%) ─────────────────────────────────────────────────── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="58">

        <!-- Google Map Fragment -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/mapFragment"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <!-- Back Button (top-left) -->
        <FrameLayout
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="top|start"
            android:layout_marginStart="16dp"
            android:layout_marginTop="48dp"
            android:background="@drawable/bg_heart_button"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="←"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold"/>

        </FrameLayout>

        <!-- Locate Me Button (top-right) -->
        <FrameLayout
            android:id="@+id/btnLocateMe"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="top|end"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="48dp"
            android:background="@drawable/bg_heart_button"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="◎"
                android:textColor="#000000"
                android:textSize="18sp"/>

        </FrameLayout>

    </FrameLayout>

    <!-- ── BOTTOM PANEL (42%) ─────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="42"
        android:orientation="vertical"
        android:background="@drawable/bg_bottom_panel"
        android:paddingTop="10dp">

        <!-- Drag Handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="14dp"
            android:background="#444444"/>

        <!-- ── Category Chips ──────────────────────────────────────────────── -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:clipToPadding="false"
            android:layout_marginBottom="18dp">

            <LinearLayout
                android:id="@+id/layoutCategories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Restaurants -->
                <LinearLayout
                    android:id="@+id/chipRestaurants"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_category_chip_selected"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginEnd="10dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🍴" android:textSize="14sp" android:layout_marginEnd="6dp"/>
                    <TextView android:id="@+id/tvChipRestaurants"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Restaurants" android:textColor="#FFFFFF"
                        android:textSize="13sp" android:textStyle="bold"/>
                </LinearLayout>

                <!-- Things to do -->
                <LinearLayout
                    android:id="@+id/chipThingsToDo"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_category_chip"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginEnd="10dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📷" android:textSize="14sp" android:layout_marginEnd="6dp"/>
                    <TextView android:id="@+id/tvChipThingsToDo"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Things to do" android:textColor="#AAAAAA" android:textSize="13sp"/>
                </LinearLayout>

                <!-- Hotels -->
                <LinearLayout
                    android:id="@+id/chipHotels"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_category_chip"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginEnd="10dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🏨" android:textSize="14sp" android:layout_marginEnd="6dp"/>
                    <TextView android:id="@+id/tvChipHotels"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Hotels" android:textColor="#AAAAAA" android:textSize="13sp"/>
                </LinearLayout>

                <!-- Temples -->
                <LinearLayout
                    android:id="@+id/chipTemples"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_category_chip"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginEnd="10dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🛕" android:textSize="14sp" android:layout_marginEnd="6dp"/>
                    <TextView android:id="@+id/tvChipTemples"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Temples" android:textColor="#AAAAAA" android:textSize="13sp"/>
                </LinearLayout>

                <!-- Tourist Spots -->
                <LinearLayout
                    android:id="@+id/chipTourist"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_category_chip"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginEnd="10dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🏛️" android:textSize="14sp" android:layout_marginEnd="6dp"/>
                    <TextView android:id="@+id/tvChipTourist"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tourist Spots" android:textColor="#AAAAAA" android:textSize="13sp"/>
                </LinearLayout>

                <!-- Kids Play -->
                <LinearLayout
                    android:id="@+id/chipKids"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_category_chip"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginEnd="10dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🎡" android:textSize="14sp" android:layout_marginEnd="6dp"/>
                    <TextView android:id="@+id/tvChipKids"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Kids Play" android:textColor="#AAAAAA" android:textSize="13sp"/>
                </LinearLayout>

                <!-- Shopping -->
                <LinearLayout
                    android:id="@+id/chipShopping"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_category_chip"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginEnd="10dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🛍️" android:textSize="14sp" android:layout_marginEnd="6dp"/>
                    <TextView android:id="@+id/tvChipShopping"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Shopping" android:textColor="#AAAAAA" android:textSize="13sp"/>
                </LinearLayout>

                <!-- Spas -->
                <LinearLayout
                    android:id="@+id/chipSpas"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/bg_category_chip"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginEnd="10dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💆" android:textSize="14sp" android:layout_marginEnd="6dp"/>
                    <TextView android:id="@+id/tvChipSpas"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Spas" android:textColor="#AAAAAA" android:textSize="13sp"/>
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- ── "Book a tour for today" + loading indicator ─────────────────── -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvSectionTitle"
                android:text="Book a tour for today"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"/>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:visibility="gone"
                android:indeterminateTint="#00C9B1"/>

        </RelativeLayout>

        <!-- ── Place Cards (Horizontal RecyclerView) ─────────────────────── -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvNearbyPlaces"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:clipToPadding="false"
            android:overScrollMode="never"/>

    </LinearLayout>

</LinearLayout>
